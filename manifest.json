{
  "manifest_version": 3,
  "name": "CopySpark",
  "version": "1.0",
  "description": "Simpan catatan penting dan salin respons AI favorit Anda hanya dengan satu klik! by RikalG22",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}